# =============================================================================
# Digital Call Board — Environment Variables
# Copy this file to .env.local and fill in real values
# =============================================================================

# --- Database ---
# Local dev: Docker PostgreSQL
DATABASE_URL=postgresql://callboard:callboard_dev@localhost:5432/callboard
# Production: Supabase pooler (port 6543, append ?pgbouncer=true)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection for migrations (port 5432)
DATABASE_URL_DIRECT=postgresql://callboard:callboard_dev@localhost:5432/callboard
# Production: Supabase direct
# DATABASE_URL_DIRECT=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- Auth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-32-byte-string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

# --- Supabase (production only, optional for local dev) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Storage ---
# "local" for dev (files saved to ./uploads/), "supabase" for production
STORAGE_PROVIDER=local

# --- Realtime ---
# "ws" for local dev WebSocket server, "supabase" for production
NEXT_PUBLIC_REALTIME_PROVIDER=ws
